    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "postman",
    "api",
    "api-testing",
    "ai",
    "llm",
    "tools",
    "claude",
    "cursor",
    "vscode",
    "copilot",
    "gemini",
    "agent",
    "openai",
    "collections",
    "rest-api"
